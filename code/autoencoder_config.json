{
    "data_path": "data/trajectories.npy",
    "template_path": "data/analysis/golden_template.npy",
    "save_dir": "data/models/autoencoder",
    "random_seed": [42, 123, 456, 789, 101112, 131415, 161718, 192021, 222324, 252627],
    "val_split": 0.15,
    "device": "auto",
    "n_epochs": 100,
    "batch_size": 32,
    "latent_dim": [2,4,8,16,32,64],
    "lr": 1e-3,
    "activation": "gelu",
    "optimizer": "adamw",
    "weight_decay": 1e-3,
    "dropout": 0.3,
    "channel_loss_weight": [3, 10],
    "cycle_weight": 0.02,
    "endpoint_weight": 5.0,
    "endpoint_samples": 5,
    "base_channels": 512,
    "derivative_weight": 0.1,
    "bottleneck_len": 12,
    "decoder_kernel_size": 5,
    "restart_on_plateau": false,
    "restart_check_epoch": 20,
    "restart_threshold": 0.022,
    "restart_max_attempts": 3
}