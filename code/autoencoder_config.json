{
    "data_path": "data/trajectories.npy",
    "template_path": "data/analysis/golden_template.npy",
    "save_dir": "data/models/autoencoder",
    "random_seed": 42,
    "val_split": 0.15,
    "device": "auto",
    "n_epochs": 100,
    "batch_size": 64,
    "latent_dim": [16, 32, 64],
    "lr": 1e-4,
    "activation": "gelu",
    "optimizer": "adamw",
    "weight_decay": [1e-3, 1e-2],
    "dropout": [0.2, 0.3, 0.4]
}